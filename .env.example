# ── Identidade do projeto ────────────────────────────────────────
# Ao clonar este template para um novo projeto, mude estas 3 linhas.
# Mantenha DB_PORT e DB_NAME consistentes com a DATABASE_URL abaixo
# (o .env não interpola variáveis — os valores são literais).

# Porta do Postgres publicada na sua máquina (5432, 5433, 5434...)
DB_PORT=5432
# Nome do banco deste projeto
DB_NAME=saas_dev
# Porta do app ao rodar via docker compose
APP_PORT=3000

# ── Conexão usada pelo app em dev (npm run dev) e pelas migrations ──
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/saas_dev

# URL pública do app — usada pelo Playwright/healthchecks e pelo Better Auth
# para validar a origem das requisições. Se você mudar APP_PORT, atualize a
# porta aqui também (os dois valores precisam bater).
BASE_URL=http://localhost:3000

# Assina sessões/cookies do Better Auth — obrigatório, mínimo 32 caracteres.
# Gere um valor único por ambiente com: openssl rand -base64 32
BETTER_AUTH_SECRET=
